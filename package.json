{
	"name": "blob",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/features/auth/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "latest",
		"@aws-sdk/s3-request-presigner": "latest",
		"@axiomhq/pino": "latest",
		"@fontsource-variable/geist": "latest",
		"@fontsource-variable/merriweather": "latest",
		"@internationalized/date": "latest",
		"@kubiks/otel-drizzle": "latest",
		"@kubiks/otel-polar": "latest",
		"@kubiks/otel-resend": "latest",
		"@opentelemetry/api": "latest",
		"@opentelemetry/auto-instrumentations-node": "latest",
		"@opentelemetry/exporter-trace-otlp-proto": "latest",
		"@opentelemetry/resources": "latest",
		"@opentelemetry/sdk-node": "latest",
		"@opentelemetry/semantic-conventions": "latest",
		"@polar-sh/better-auth": "latest",
		"@polar-sh/sdk": "latest",
		"@tabler/icons-svelte": "latest",
		"@tanstack/table-core": "latest",
		"better-auth": "latest",
		"better-svelte-email": "latest",
		"bits-ui": "latest",
		"clsx": "latest",
		"date-fns": "latest",
		"dotenv": "latest",
		"drizzle-orm": "latest",
		"embla-carousel-svelte": "latest",
		"formsnap": "latest",
		"import-in-the-middle": "latest",
		"ioredis": "latest",
		"layerchart": "latest",
		"mode-watcher": "latest",
		"paneforge": "latest",
		"pino": "latest",
		"pino-pretty": "latest",
		"postgres": "latest",
		"resend": "latest",
		"runed": "latest",
		"svelte": "latest",
		"svelte-sonner": "latest",
		"svelte-toolbelt": "latest",
		"sveltekit-rate-limiter": "latest",
		"tailwind-merge": "latest",
		"tailwind-variants": "latest",
		"tw-animate-css": "latest",
		"uuidv7": "latest",
		"vaul-svelte": "latest",
		"zod": "latest"
	},
	"devDependencies": {
		"@better-auth/cli": "latest",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "latest",
		"@sveltejs/adapter-node": "latest",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"pnpm": {
		"patchedDependencies": {
			"@sveltejs/kit": "patches/@sveltejs__kit.patch"
		}
	}
}
